# Required. Needs Zone:Read (zone discovery) + SSL and Certificates:Edit on each zone.
CF_API_TOKEN=

# Zones to manage, in priority order. The first entry is the default target for new
# custom hostnames. Empty = every zone the token can see.
CF_DOMAINS=multidesk.top

# Extra suffixes never turned into custom hostnames.
# Managed zone names are added automatically, so this is usually empty.
INTERNAL_SUFFIXES=

RECONCILE_INTERVAL=3600
DEBOUNCE_SECONDS=5
ZONE_CACHE_TTL=900

MAX_DELETIONS_PER_RUN=5
MAX_DELETION_RATIO=0.3
DRY_RUN=false

LOG_LEVEL=INFO
LOG_FORMAT=text
HEALTH_PORT=8080
